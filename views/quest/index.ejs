<%
  const dailyDoneCount = dailyQuests.filter((quest) => quest.status === 'DONE').length;
  const weeklyDoneCount = weeklyQuests.filter((quest) => quest.status === 'DONE').length;
  const tierState = tierProgress || {};
  const formatPointSource = (sourceType) => {
    if (sourceType === 'QUEST') return '퀘스트';
    if (sourceType === 'BONUS') return '보너스';
    if (sourceType === 'TUTORIAL') return '튜토리얼';
    return '조정';
  };
  const formatPointHistoryDate = (value) => {
    const date = new Date(value);
    if (Number.isNaN(date.getTime())) return '';
    return date.toLocaleString('ko-KR', {
      month: 'numeric',
      day: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    });
  };
%>

<div class="page active">
  <section class="page-header">
    <div>
      <h1>퀘스트</h1>
      <p class="muted">미션을 완료하고 포인트를 모아보세요!</p>
    </div>
  </section>

  <div class="grid two quest-overview-grid">
    <div class="card hero tier-hero">
      <div class="card-header">
        <div>
          <h3>나의 포인트</h3>
          <p class="hero-subtitle">현재 티어 진행도</p>
        </div>
        <span class="tier-badge"><%= currentTier.name %></span>
      </div>

      <div class="hero-metrics">
        <div>
          <span class="metric"><%= totalPoints.toLocaleString() %></span>
          <span class="metric-label">P</span>
        </div>
      </div>

      <div class="tier-copy">
        <% if (tierState.isMaxTier) { %>
          <p class="tier-progress">최고 티어를 달성했어요.</p>
          <span class="tier-progress-caption">현재 티어 기준 완료</span>
        <% } else { %>
          <p class="tier-progress">
            다음 티어 <strong><%= nextTier.name %></strong>까지
            <strong><%= tierState.remainingPoints.toLocaleString() %>P</strong>
          </p>
          <span class="tier-progress-caption">
            <%= tierState.pointsInTier.toLocaleString() %> / <%= tierState.pointsNeeded.toLocaleString() %>P
          </span>
        <% } %>
      </div>

      <div class="tier-progress-rail" aria-label="티어 진행도">
        <div class="tier-progress-fill" style="width: <%= tierState.percent || 0 %>%"></div>
      </div>

      <% if (!tierState.isMaxTier) { %>
        <div class="tier-progress-scale">
          <span><%= tierState.startPoints.toLocaleString() %>P</span>
          <span><%= tierState.endPoints.toLocaleString() %>P</span>
        </div>
      <% } %>
    </div>

    <div class="card">
      <div class="card-header">
        <h3>오늘의 현황</h3>
      </div>
      <div class="stat-list">
        <div class="stat">
          <span>완료한 운동</span>
          <strong><%= stats.todaySessions %>회</strong>
        </div>
        <div class="stat">
          <span>이번 주 운동 일수</span>
          <strong><%= stats.weeklyDays %>일</strong>
        </div>
      </div>
    </div>
  </div>

  <div class="quest-section">
    <div class="section-header">
      <h2>일일 퀘스트</h2>
      <span class="quest-summary"><%= dailyDoneCount %>/<%= dailyQuests.length %> 완료</span>
    </div>

    <% if (dailyQuests.length === 0) { %>
      <div class="empty-state">
        <p>오늘의 퀘스트가 없습니다.</p>
        <p class="muted">운동을 시작하면 퀘스트가 자동으로 할당됩니다.</p>
      </div>
    <% } else { %>
      <div class="quest-grid">
        <% dailyQuests.forEach((quest) => { %>
          <div class="quest-card <%= quest.status === 'DONE' ? 'completed' : '' %>" data-quest-id="<%= quest.user_quest_id %>">
            <div class="quest-card-header">
              <span class="quest-type <%= quest.quest_template.type.toLowerCase() %>"><%= quest.type_label %></span>
              <span class="quest-reward">+<%= quest.quest_template.reward_points %>P</span>
            </div>
            <h4 class="quest-title"><%= quest.quest_template.title %></h4>
            <% if (quest.status === 'DONE') { %>
              <div class="quest-status completed">
                <span>완료!</span>
              </div>
            <% } else { %>
              <div class="quest-progress-bar">
                <%
                  const progressView = quest.progress_view || {};
                  const percent = progressView.percent || 0;
                  const canClaim = progressView.canClaim;
                  const unitLabel = progressView.unitLabel || '';
                %>
                <div class="progress">
                  <div class="progress-bar" style="width: <%= percent %>%"></div>
                </div>
                <span class="progress-text"><%= progressView.currentDisplay || 0 %>/<%= progressView.targetDisplay || 0 %><%= unitLabel %></span>
              </div>
              <% if (canClaim) { %>
                <button class="claim-btn" onclick="claimQuest('<%= quest.user_quest_id %>', this)">
                  보상 받기
                </button>
              <% } %>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="quest-section">
    <div class="section-header">
      <h2>주간 퀘스트</h2>
      <span class="quest-summary"><%= weeklyDoneCount %>/<%= weeklyQuests.length %> 완료</span>
    </div>

    <% if (weeklyQuests.length === 0) { %>
      <div class="empty-state">
        <p>이번 주 퀘스트가 없습니다.</p>
        <p class="muted">매주 새로운 퀘스트가 할당됩니다.</p>
      </div>
    <% } else { %>
      <div class="quest-grid">
        <% weeklyQuests.forEach((quest) => { %>
          <div class="quest-card weekly <%= quest.status === 'DONE' ? 'completed' : '' %>" data-quest-id="<%= quest.user_quest_id %>">
            <div class="quest-card-header">
              <span class="quest-type <%= quest.quest_template.type.toLowerCase() %>"><%= quest.type_label %></span>
              <span class="quest-reward">+<%= quest.quest_template.reward_points %>P</span>
            </div>
            <h4 class="quest-title"><%= quest.quest_template.title %></h4>
            <% if (quest.status === 'DONE') { %>
              <div class="quest-status completed">
                <span>완료!</span>
              </div>
            <% } else { %>
              <div class="quest-progress-bar">
                <%
                  const progressView = quest.progress_view || {};
                  const percent = progressView.percent || 0;
                  const canClaim = progressView.canClaim;
                  const unitLabel = progressView.unitLabel || '';
                %>
                <div class="progress">
                  <div class="progress-bar weekly" style="width: <%= percent %>%"></div>
                </div>
                <span class="progress-text"><%= progressView.currentDisplay || 0 %>/<%= progressView.targetDisplay || 0 %><%= unitLabel %></span>
              </div>
              <% if (canClaim) { %>
                <button class="claim-btn weekly" onclick="claimQuest('<%= quest.user_quest_id %>', this)">
                  보상 받기
                </button>
              <% } %>
            <% } %>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>

  <div class="card">
    <div class="card-header">
      <h3>최근 포인트 이력</h3>
      <span class="history-caption">최신 5건</span>
    </div>
    <% if (pointHistory.length === 0) { %>
      <p class="muted">아직 포인트 이력이 없습니다.</p>
    <% } else { %>
      <ul class="point-history">
        <% pointHistory.forEach((record) => { %>
          <li class="point-record">
            <div class="point-info">
              <span class="point-note"><%= record.note || '포인트 획득' %></span>
              <div class="point-meta">
                <span class="point-source <%= record.source_type.toLowerCase() %>"><%= formatPointSource(record.source_type) %></span>
                <span class="point-date"><%= formatPointHistoryDate(record.created_at) %></span>
              </div>
            </div>
            <div class="point-value <%= record.points >= 0 ? 'positive' : 'negative' %>">
              <%= record.points >= 0 ? '+' : '' %><%= record.points %>P
            </div>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </div>
</div>

<style>
  .quest-overview-grid {
    align-items: stretch;
  }

  .quest-overview-grid > .card {
    gap: 12px;
    padding: 16px 18px;
  }

  .quest-overview-grid .card-header {
    align-items: flex-start;
  }

  .tier-hero {
    gap: 12px;
  }

  .hero-subtitle {
    margin: 2px 0 0;
    color: rgba(255, 255, 255, 0.78);
    font-size: 12px;
  }

  .quest-section {
    margin-top: 24px;
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
  }

  .section-header h2 {
    margin: 0;
    font-size: 20px;
  }

  .quest-summary {
    background: var(--accent);
    color: white;
    padding: 6px 14px;
    border-radius: 999px;
    font-size: 13px;
    font-weight: 600;
    white-space: nowrap;
  }

  .tier-copy {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .tier-badge {
    background: rgba(255, 255, 255, 0.22);
    padding: 6px 14px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 14px;
    width: fit-content;
  }

  .tier-progress {
    margin: 0;
    font-size: 14px;
    line-height: 1.4;
  }

  .tier-progress-caption {
    color: rgba(255, 255, 255, 0.82);
    font-size: 12px;
  }

  .tier-progress-rail {
    width: 100%;
    height: 8px;
    border-radius: 999px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.22);
  }

  .tier-progress-fill {
    height: 100%;
    border-radius: inherit;
    background: linear-gradient(90deg, #ffffff 0%, #c7d2fe 100%);
  }

  .tier-progress-scale {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    color: rgba(255, 255, 255, 0.78);
  }

  .quest-overview-grid .stat-list {
    gap: 10px;
  }

  .quest-overview-grid .stat {
    padding: 10px 12px;
  }

  .quest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 16px;
  }

  .quest-card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: all 0.2s ease;
  }

  .quest-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .quest-card.completed {
    background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
    border-color: #86efac;
  }

  .quest-card.weekly {
    border-left: 4px solid var(--primary);
  }

  .quest-card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
  }

  .quest-type {
    padding: 4px 10px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
  }

  .quest-type.do {
    background: rgba(59, 130, 246, 0.15);
    color: #3b82f6;
  }

  .quest-type.quality {
    background: rgba(245, 158, 11, 0.15);
    color: #f59e0b;
  }

  .quest-type.habit {
    background: rgba(139, 92, 246, 0.15);
    color: #8b5cf6;
  }

  .quest-type.challenge {
    background: rgba(16, 185, 129, 0.15);
    color: #10b981;
  }

  .quest-reward {
    font-weight: 700;
    color: var(--accent);
    white-space: nowrap;
  }

  .quest-title {
    margin: 0;
    font-size: 15px;
    font-weight: 600;
    color: var(--text);
  }

  .quest-progress-bar {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .quest-progress-bar .progress {
    flex: 1;
  }

  .quest-progress-bar .progress-bar.weekly {
    background: var(--primary);
  }

  .progress-text {
    font-size: 13px;
    font-weight: 600;
    color: var(--muted);
    min-width: 52px;
    text-align: right;
  }

  .quest-status.completed {
    color: #16a34a;
    font-weight: 600;
  }

  .empty-state {
    background: var(--card);
    border: 2px dashed var(--border);
    border-radius: 16px;
    padding: 40px;
    text-align: center;
  }

  .empty-state p {
    margin: 0;
  }

  .empty-state .muted {
    margin-top: 8px;
  }

  .history-caption {
    color: var(--muted);
    font-size: 12px;
    font-weight: 600;
  }

  .point-history {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .point-record {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 14px 16px;
    background: var(--input-bg);
    border-radius: 14px;
  }

  .point-info {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
  }

  .point-note {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
    word-break: keep-all;
  }

  .point-meta {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
    color: var(--muted);
    font-size: 12px;
  }

  .point-source {
    display: inline-flex;
    align-items: center;
    padding: 3px 8px;
    border-radius: 999px;
    font-size: 11px;
    font-weight: 700;
    background: rgba(15, 23, 42, 0.08);
    color: var(--text);
  }

  .point-value {
    font-size: 16px;
    font-weight: 700;
    white-space: nowrap;
  }

  .point-value.positive {
    color: var(--accent);
  }

  .point-value.negative {
    color: var(--danger);
  }

  .claim-btn {
    width: 100%;
    padding: 12px 16px;
    margin-top: 8px;
    border: none;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--accent) 0%, #00a896 100%);
    color: white;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
    animation: pulse 2s infinite;
  }

  .claim-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(0, 194, 168, 0.4);
  }

  .claim-btn.weekly {
    background: linear-gradient(135deg, var(--primary) 0%, #7c54ff 100%);
  }

  .claim-btn.weekly:hover {
    box-shadow: 0 6px 20px rgba(91, 108, 255, 0.4);
  }

  .claim-btn:disabled {
    opacity: 0.65;
    cursor: wait;
    animation: none;
  }

  @keyframes pulse {
    0%, 100% { box-shadow: 0 0 0 0 rgba(0, 194, 168, 0.4); }
    50% { box-shadow: 0 0 0 8px rgba(0, 194, 168, 0); }
  }

  .toast {
    position: fixed;
    right: 24px;
    bottom: 24px;
    z-index: 1000;
    padding: 16px 24px;
    border-radius: 12px;
    color: white;
    font-weight: 500;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
    background: #0f172a;
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.3s ease;
  }

  .toast.show {
    transform: translateY(0);
    opacity: 1;
  }

  .toast.success {
    background: linear-gradient(135deg, #16a34a 0%, #22c55e 100%);
  }

  .toast.error {
    background: linear-gradient(135deg, #dc2626 0%, #ef4444 100%);
  }

  @media (max-width: 768px) {
    .section-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .quest-grid {
      grid-template-columns: 1fr;
    }

    .point-record {
      align-items: flex-start;
      flex-direction: column;
    }

    .point-value {
      align-self: flex-end;
    }

    .toast {
      left: 16px;
      right: 16px;
      bottom: 16px;
    }
  }
</style>

<script>
  function showToast(message, type = 'success') {
    const existingToast = document.querySelector('.toast');
    if (existingToast) {
      existingToast.remove();
    }

    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.textContent = message;
    document.body.appendChild(toast);

    setTimeout(() => toast.classList.add('show'), 10);
    setTimeout(() => {
      toast.classList.remove('show');
      setTimeout(() => toast.remove(), 300);
    }, 3000);
  }

  (function restoreQuestToast() {
    try {
      const raw = sessionStorage.getItem('questToast');
      if (!raw) {
        return;
      }

      sessionStorage.removeItem('questToast');
      const saved = JSON.parse(raw);
      if (saved && saved.message) {
        showToast(saved.message, saved.type || 'success');
      }
    } catch (error) {
      console.error('Toast restore error:', error);
    }
  })();

  async function claimQuest(questId, btn) {
    btn.disabled = true;
    btn.textContent = '갱신 중...';

    try {
      const response = await fetch(`/api/quest/${questId}/claim`, {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        }
      });

      const data = await response.json();

      if (!response.ok || !data.success) {
        showToast(data.error || '오류가 발생했습니다.', 'error');
        btn.disabled = false;
        btn.textContent = '보상 받기';
        return;
      }

      try {
        sessionStorage.setItem('questToast', JSON.stringify({
          message: data.message,
          type: 'success'
        }));
      } catch (storageError) {
        console.error('Toast save error:', storageError);
      }

      window.location.reload();
    } catch (error) {
      console.error('Claim error:', error);
      showToast('네트워크 오류가 발생했습니다.', 'error');
      btn.disabled = false;
      btn.textContent = '보상 받기';
    }
  }
</script>
