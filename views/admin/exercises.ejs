<div class="admin-header">
    <h1>운동 관리</h1>
    <button class="btn btn-primary" onclick="document.getElementById('addModal').style.display='flex'">
        + 운동 추가
    </button>
</div>

<div class="admin-card">
    <% if (exercises.length === 0) { %>
        <div class="empty-state">
            <div class="empty-state-icon">🏋️</div>
            <div class="empty-state-title">등록된 운동이 없습니다</div>
            <p>새로운 운동을 추가해보세요.</p>
        </div>
    <% } else { %>
        <table class="admin-table">
            <thead>
                <tr>
                    <th>코드</th>
                    <th>이름</th>
                    <th>설명</th>
                    <th>상태</th>
                    <th>관리</th>
                </tr>
            </thead>
            <tbody>
                <% exercises.forEach(exercise => { %>
                    <tr>
                        <td><code><%= exercise.code %></code></td>
                        <td><strong><%= exercise.name %></strong></td>
                        <td><%= exercise.description || '-' %></td>
                        <td>
                            <% if (exercise.is_active) { %>
                                <span class="badge badge-success">활성</span>
                            <% } else { %>
                                <span class="badge badge-danger">비활성</span>
                            <% } %>
                        </td>
                        <td>
                            <div class="action-btns">
                                <button class="btn btn-sm btn-secondary" onclick="openEditModal('<%= exercise.exercise_id %>', '<%= exercise.code %>', '<%= exercise.name %>', '<%= exercise.description || '' %>', <%= exercise.is_active %>)">
                                    수정
                                </button>
                                <form action="/admin/exercises/<%= exercise.exercise_id %>/delete" method="POST" style="display:inline;" onsubmit="return confirm('정말 삭제하시겠습니까?');">
                                    <button type="submit" class="btn btn-sm btn-danger">삭제</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    <% } %>
</div>

<!-- 추가 모달 -->
<div id="addModal" class="modal-overlay" style="display: none;">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">운동 추가</h3>
            <button class="modal-close" onclick="document.getElementById('addModal').style.display='none'">&times;</button>
        </div>
        <form action="/admin/exercises" method="POST">
            <div class="form-group">
                <label class="form-label">코드 *</label>
                <input type="text" name="code" class="form-input" placeholder="PUSH_UP" required pattern="[A-Z0-9_]+" />
                <div class="form-hint">영문 대문자, 숫자, 밑줄만 사용 (예: PUSH_UP, SQUAT)</div>
            </div>
            <div class="form-group">
                <label class="form-label">이름 *</label>
                <input type="text" name="name" class="form-input" placeholder="푸시업" required />
            </div>
            <div class="form-group">
                <label class="form-label">설명</label>
                <textarea name="description" class="form-textarea" placeholder="운동에 대한 설명..."></textarea>
            </div>
            <div class="form-group">
                <label class="toggle">
                    <input type="checkbox" name="is_active" checked />
                    <span class="toggle-slider"></span>
                </label>
                <span style="margin-left: 12px;">활성화</span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('addModal').style.display='none'">취소</button>
                <button type="submit" class="btn btn-primary">추가</button>
            </div>
        </form>
    </div>
</div>

<!-- 수정 모달 -->
<div id="editModal" class="modal-overlay" style="display: none;">
    <div class="modal">
        <div class="modal-header">
            <h3 class="modal-title">운동 수정</h3>
            <button class="modal-close" onclick="document.getElementById('editModal').style.display='none'">&times;</button>
        </div>
        <form id="editForm" method="POST">
            <div class="form-group">
                <label class="form-label">코드 *</label>
                <input type="text" name="code" id="edit_code" class="form-input" required pattern="[A-Z0-9_]+" />
            </div>
            <div class="form-group">
                <label class="form-label">이름 *</label>
                <input type="text" name="name" id="edit_name" class="form-input" required />
            </div>
            <div class="form-group">
                <label class="form-label">설명</label>
                <textarea name="description" id="edit_description" class="form-textarea"></textarea>
            </div>
            <div class="form-group">
                <label class="toggle">
                    <input type="checkbox" name="is_active" id="edit_is_active" />
                    <span class="toggle-slider"></span>
                </label>
                <span style="margin-left: 12px;">활성화</span>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" onclick="document.getElementById('editModal').style.display='none'">취소</button>
                <button type="submit" class="btn btn-primary">저장</button>
            </div>
        </form>
    </div>
</div>

<script>
function openEditModal(id, code, name, description, isActive) {
    document.getElementById('editForm').action = '/admin/exercises/' + id;
    document.getElementById('edit_code').value = code;
    document.getElementById('edit_name').value = name;
    document.getElementById('edit_description').value = description;
    document.getElementById('edit_is_active').checked = isActive;
    document.getElementById('editModal').style.display = 'flex';
}
</script>
